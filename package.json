{
  "name": "watchtower",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/web",
    "test": "npm run test --workspaces",
    "test:sdk": "npm run test --workspace=packages/sdk",
    "test:web": "npm run test --workspace=packages/web"
  }
}
